---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'La plateforme de révisions STMG : cours, QCM, fiches et sujets de bac pour toutes les matières Éco-Gestion.' } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | ÉcoGestion STMG</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body class="min-h-screen">
    <!-- Navigation -->
    <nav class="sticky top-0 z-50 glass border-b border-white/30">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-3 group">
            <div class="w-10 h-10 rounded-2xl bg-gradient-to-br from-droit-500 via-mercatique-500 to-eco-500 flex items-center justify-center shadow-lg group-hover:shadow-xl transition-shadow">
              <span class="text-white font-display font-bold text-lg">É</span>
            </div>
            <div>
              <span class="font-display font-bold text-lg tracking-tight">ÉcoGestion</span>
              <span class="text-xs text-gray-400 block -mt-1 font-body">STMG</span>
            </div>
          </a>

          <!-- Desktop Nav -->
          <div class="hidden md:flex items-center gap-1">
            <div class="relative group">
              <button class="flex items-center gap-1.5 px-4 py-2 rounded-xl text-sm font-medium text-gray-600 hover:text-ink hover:bg-white/60 transition-all">
                <span>📘</span> Première
                <svg class="w-3.5 h-3.5 opacity-50 group-hover:opacity-100 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
              </button>
              <div class="absolute top-full left-0 mt-1 w-56 bg-white rounded-2xl shadow-xl border border-gray-100 py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform group-hover:translate-y-0 translate-y-2">
                <a href="/premiere/droit" class="flex items-center gap-3 px-4 py-2.5 text-sm hover:bg-droit-50 text-gray-700 hover:text-droit-700 transition-colors">
                  <span class="w-2 h-2 rounded-full bg-droit-500"></span> Droit
                </a>
                <a href="/premiere/economie" class="flex items-center gap-3 px-4 py-2.5 text-sm hover:bg-eco-50 text-gray-700 hover:text-eco-700 transition-colors">
                  <span class="w-2 h-2 rounded-full bg-eco-500"></span> Économie
                </a>
                <a href="/premiere/management" class="flex items-center gap-3 px-4 py-2.5 text-sm hover:bg-management-50 text-gray-700 hover:text-management-700 transition-colors">
                  <span class="w-2 h-2 rounded-full bg-management-500"></span> Management
                </a>
                <a href="/premiere/sdgn" class="flex items-center gap-3 px-4 py-2.5 text-sm hover:bg-sdgn-50 text-gray-700 hover:text-sdgn-700 transition-colors opacity-50 cursor-not-allowed">
                  <span class="w-2 h-2 rounded-full bg-sdgn-500"></span> SDGN <span class="badge bg-gray-100 text-gray-500 text-[10px] ml-auto">Bientôt</span>
                </a>
              </div>
            </div>
            
            <div class="relative group">
              <button class="flex items-center gap-1.5 px-4 py-2 rounded-xl text-sm font-medium text-gray-600 hover:text-ink hover:bg-white/60 transition-all">
                <span>🎓</span> Terminale
                <svg class="w-3.5 h-3.5 opacity-50 group-hover:opacity-100 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
              </button>
              <div class="absolute top-full left-0 mt-1 w-56 bg-white rounded-2xl shadow-xl border border-gray-100 py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform group-hover:translate-y-0 translate-y-2">
                <a href="/terminale/droit" class="flex items-center gap-3 px-4 py-2.5 text-sm hover:bg-droit-50 text-gray-700 hover:text-droit-700 transition-colors">
                  <span class="w-2 h-2 rounded-full bg-droit-600"></span> Droit
                </a>
                <a href="/terminale/economie" class="flex items-center gap-3 px-4 py-2.5 text-sm hover:bg-eco-50 text-gray-700 hover:text-eco-700 transition-colors">
                  <span class="w-2 h-2 rounded-full bg-eco-600"></span> Économie
                </a>
                <a href="/terminale/mercatique" class="flex items-center gap-3 px-4 py-2.5 text-sm hover:bg-mercatique-50 text-gray-700 hover:text-mercatique-700 transition-colors">
                  <span class="w-2 h-2 rounded-full bg-mercatique-500"></span> Mercatique
                </a>
                <a href="/terminale/msdgn" class="flex items-center gap-3 px-4 py-2.5 text-sm hover:bg-msdgn-50 text-gray-700 hover:text-msdgn-700 transition-colors">
                  <span class="w-2 h-2 rounded-full bg-msdgn-500"></span> MSDGN
                </a>
              </div>
            </div>

            <a href="/outils" class="flex items-center gap-1.5 px-4 py-2 rounded-xl text-sm font-medium text-gray-600 hover:text-ink hover:bg-white/60 transition-all">
              <span>🧰</span> Outils
            </a>
          </div>

          <!-- Mobile menu button -->
          <button id="mobile-menu-btn" class="md:hidden p-2 rounded-xl hover:bg-white/60 transition-colors" aria-label="Menu">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
          </button>
        </div>
      </div>
      
      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden bg-white/95 backdrop-blur-xl border-t border-gray-100 pb-4">
        <div class="px-4 py-3 space-y-1">
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider px-3 pt-2">Première</p>
          <a href="/premiere/droit" class="flex items-center gap-3 px-3 py-2 rounded-xl text-sm hover:bg-droit-50">⚖️ Droit</a>
          <a href="/premiere/economie" class="flex items-center gap-3 px-3 py-2 rounded-xl text-sm hover:bg-eco-50">📊 Économie</a>
          <a href="/premiere/management" class="flex items-center gap-3 px-3 py-2 rounded-xl text-sm hover:bg-management-50">🎯 Management</a>
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider px-3 pt-4">Terminale</p>
          <a href="/terminale/droit" class="flex items-center gap-3 px-3 py-2 rounded-xl text-sm hover:bg-droit-50">⚖️ Droit</a>
          <a href="/terminale/economie" class="flex items-center gap-3 px-3 py-2 rounded-xl text-sm hover:bg-eco-50">📊 Économie</a>
          <a href="/terminale/mercatique" class="flex items-center gap-3 px-3 py-2 rounded-xl text-sm hover:bg-mercatique-50">🎨 Mercatique</a>
          <a href="/terminale/msdgn" class="flex items-center gap-3 px-3 py-2 rounded-xl text-sm hover:bg-msdgn-50">🧩 MSDGN</a>
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider px-3 pt-4">Outils</p>
          <a href="/outils" class="flex items-center gap-3 px-3 py-2 rounded-xl text-sm hover:bg-gray-50">🧰 Tous les outils</a>
        </div>
      </div>
    </nav>

    <!-- Main content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="mt-24 border-t border-gray-200/60 bg-white/40">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <div class="md:col-span-2">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-2xl bg-gradient-to-br from-droit-500 via-mercatique-500 to-eco-500 flex items-center justify-center">
                <span class="text-white font-display font-bold text-lg">É</span>
              </div>
              <span class="font-display font-bold text-lg">ÉcoGestion STMG</span>
            </div>
            <p class="text-sm text-gray-500 max-w-md leading-relaxed">
              Plateforme gratuite de révisions pour les élèves de Première et Terminale STMG. 
              Cours, QCM, fiches de synthèse et sujets de bac corrigés dans toutes les matières Éco-Gestion.
            </p>
          </div>
          <div>
            <h4 class="font-display font-semibold text-sm mb-3">Première</h4>
            <ul class="space-y-2 text-sm text-gray-500">
              <li><a href="/premiere/droit" class="hover:text-droit-600 transition-colors">Droit</a></li>
              <li><a href="/premiere/economie" class="hover:text-eco-600 transition-colors">Économie</a></li>
              <li><a href="/premiere/management" class="hover:text-management-600 transition-colors">Management</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-display font-semibold text-sm mb-3">Terminale</h4>
            <ul class="space-y-2 text-sm text-gray-500">
              <li><a href="/terminale/droit" class="hover:text-droit-600 transition-colors">Droit</a></li>
              <li><a href="/terminale/economie" class="hover:text-eco-600 transition-colors">Économie</a></li>
              <li><a href="/terminale/mercatique" class="hover:text-mercatique-600 transition-colors">Mercatique</a></li>
              <li><a href="/terminale/msdgn" class="hover:text-msdgn-600 transition-colors">MSDGN</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-10 pt-6 border-t border-gray-200/60 flex flex-col sm:flex-row justify-between items-center gap-4">
          <p class="text-xs text-gray-400">© 2026 ÉcoGestion STMG — Réalisé par M. Seddar & collègues · Académie de Créteil</p>
          <div class="flex items-center gap-4 text-xs text-gray-400">
            <a href="/mentions-legales" class="hover:text-gray-600 transition-colors">Mentions légales</a>
            <a href="/contact" class="hover:text-gray-600 transition-colors">Contact</a>
          </div>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    </script>

    <script>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", user => {
          if (!user) {
            window.netlifyIdentity.on("login", () => {
              document.location.href = "/admin/";
            });
          }
        });
      }
    </script>
  </body>
</html>
