---
import Layout from '../../layouts/Layout.astro';
import SimulateurBac from '../../components/SimulateurBac';
---

<Layout title="📊 Simulateur de note au bac STMG">
  
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-10 text-center">
      <nav class="flex items-center justify-center gap-2 text-sm text-gray-400 mb-6">
        <a href="/" class="hover:text-gray-600 transition-colors">Accueil</a>
        <span>/</span>
        <a href="/outils" class="hover:text-gray-600 transition-colors">Outils</a>
        <span>/</span>
        <span class="text-gray-600">Simulateur</span>
      </nav>
      
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-3xl bg-gradient-to-br from-eco-500 to-eco-600 shadow-xl mb-6">
        <span class="text-3xl">📊</span>
      </div>
      <h1 class="font-display font-extrabold text-3xl sm:text-4xl">Simulateur de note au bac</h1>
      <p class="text-gray-500 mt-3 max-w-md mx-auto">
        Entre tes notes réelles ou estimées pour calculer ta moyenne et ta mention au bac STMG.
      </p>
    </div>

    <SimulateurBac client:load />
  </section>

</Layout>
