---
import Layout from '../../layouts/Layout.astro';

const BASE_URL = 'https://crcom.ac-versailles.fr/';

const droitEco = [
  { title: "SARL ArchiDij97", session: "Metropole 2025", url: "IMG/pdf/25-_sujet_mgdeme1_vf.pdf", year: 2025 },
  { title: "SARL Croqu' Provence", session: "Centres etrangers 2025", url: "IMG/pdf/25-mgdeg11_v1_2_1_.pdf", year: 2025 },
  { title: "SARL OGALAU", session: "Asie 2025", url: "IMG/pdf/stmg-spe-droit-economie-2025-asie-sujet-officiel.pdf", year: 2025 },
  { title: "SARL Camelia", session: "Metropole 2024", url: "IMG/pdf/24_mgdeme_1_.pdf", year: 2024 },
  { title: "MODISTES DU NORD", session: "Asie 2024", url: "IMG/pdf/stmg-spe-droit-economie-2024-asie-sujet-officiel.pdf", year: 2024 },
  { title: "SARL Carrelages 2000", session: "Centres etrangers 2024", url: "IMG/pdf/stmg-spe-droit-economie-2024-centres-etrangers-sujet-officiel.pdf", year: 2024 },
  { title: "SARL Pompes a Chaleur", session: "Metropole 2023", url: "IMG/pdf/stmg_droit_et_economie_metropole_2023.pdf", year: 2023 },
  { title: "Lisa Dupont, Boisier", session: "Polynesie 2023", url: "IMG/pdf/stmg_-_droit_et_economie_polynesie_francaise_2023.pdf", year: 2023 },
  { title: "Marc Ponteau", session: "Centres etrangers 2023", url: "IMG/pdf/23-mgdeg11.pdf", year: 2023 },
  { title: "Nicole et Richard", session: "Metropole 2022", url: "IMG/pdf/sujet_droit_eco_metropole_2022.pdf", year: 2022 },
  { title: "Les epoux Bastide", session: "Polynesie 2022", url: "IMG/pdf/sujet_2022_droit_et_economie_polynesie.pdf", year: 2022 },
  { title: "SA Energymax", session: "Metropole 2021", url: "IMG/pdf/sujet_droit_eco_stmg_metropole_2021.pdf", year: 2021 },
  { title: "Velofood", session: "Sujet zero 2021", url: "IMG/pdf/sujet_zero_session_2021_droit_economie_sujet.pdf", year: 2021 },
];

const msdgn = [
  { title: "Cas Bebe Serein", session: "Metropole 2025", url: "IMG/pdf/stmg-spe-management-gestion-numerique-2025-metropole-sujet-officiel.pdf", year: 2025 },
  { title: "La dorure artisanale", session: "Asie 2025", url: "IMG/pdf/stmg_spe_management_gestion_numerique_2025_asie_sujet_officiel_1_.pdf", year: 2025 },
  { title: "Cas Heriland", session: "Centres etrangers 2025", url: "IMG/pdf/25-mgmsgng11_v2.pdf", year: 2025 },
  { title: "Topschuss", session: "Metropole 2024", url: "IMG/pdf/stmg-spe-management-gestion-numerique-2024-metropole-sujet-officiel.pdf", year: 2024 },
  { title: "Eyecontact", session: "Asie 2024", url: "IMG/pdf/stmg-spe-management-gestion-numerique-2024-asie-sujet-officiel.pdf", year: 2024 },
  { title: "OPC", session: "Centres etrangers 2024", url: "IMG/pdf/stmg-spe-management-gestion-numerique-2024-centres-etrangers-sujet-officiel.pdf", year: 2024 },
  { title: "Renou Textiles", session: "Polynesie 2024", url: "IMG/pdf/24-mgmsgnpo1.pdf", year: 2024 },
  { title: "Transports Ybra", session: "Remplacement 2024", url: "IMG/pdf/24-mgmsgnme3.pdf", year: 2024 },
  { title: "Le Marin Celtik", session: "Remplacement 2024", url: "IMG/pdf/24-mgmsgnme2.pdf", year: 2024 },
];

// Group by year
function groupByYear(items: typeof droitEco) {
  const grouped: Record<number, typeof droitEco> = {};
  for (const item of items) {
    if (!grouped[item.year]) grouped[item.year] = [];
    grouped[item.year].push(item);
  }
  return Object.entries(grouped)
    .sort(([a], [b]) => Number(b) - Number(a))
    .map(([year, items]) => ({ year: Number(year), items }));
}

const droitEcoByYear = groupByYear(droitEco);
const msdgnByYear = groupByYear(msdgn);
---

<Layout title="📝 Sujets de bac officiels - STMG">

  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Breadcrumb -->
    <nav class="flex items-center justify-center gap-2 text-sm text-gray-400 mb-8">
      <a href="/" class="hover:text-gray-600 transition-colors">Accueil</a>
      <span>/</span>
      <a href="/outils" class="hover:text-gray-600 transition-colors">Outils</a>
      <span>/</span>
      <span class="text-gray-600">Sujets de bac</span>
    </nav>

    <!-- Hero -->
    <div class="text-center mb-14">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-3xl bg-gradient-to-br from-rose-500 to-red-500 shadow-xl mb-6">
        <span class="text-3xl">📝</span>
      </div>
      <h1 class="font-display font-extrabold text-3xl sm:text-4xl mb-3">Sujets de bac officiels</h1>
      <p class="text-gray-500 max-w-lg mx-auto mb-8">
        Retrouve tous les sujets officiels du bac STMG classes par matiere et par annee. Source : CRCOM Academie de Versailles.
      </p>

      <!-- Stats -->
      <div class="flex items-center justify-center gap-6">
        <div class="glass rounded-2xl px-5 py-3 text-center">
          <p class="font-display font-extrabold text-2xl gradient-text">{droitEco.length + msdgn.length}</p>
          <p class="text-xs text-gray-500 mt-0.5">sujets au total</p>
        </div>
        <div class="glass rounded-2xl px-5 py-3 text-center">
          <p class="font-display font-extrabold text-2xl gradient-text">2</p>
          <p class="text-xs text-gray-500 mt-0.5">matieres</p>
        </div>
        <div class="glass rounded-2xl px-5 py-3 text-center">
          <p class="font-display font-extrabold text-2xl gradient-text">2021-2025</p>
          <p class="text-xs text-gray-500 mt-0.5">sessions</p>
        </div>
      </div>
    </div>

    <!-- ============================================= -->
    <!-- DROIT ET ECONOMIE -->
    <!-- ============================================= -->
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center shadow-md">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
          </svg>
        </div>
        <h2 class="font-display font-extrabold text-2xl">Droit et Economie</h2>
        <span class="badge bg-blue-100 text-blue-700 text-xs">{droitEco.length} sujets</span>
        <div class="h-px flex-1 bg-gray-200"></div>
      </div>

      {droitEcoByYear.map(({ year, items }) => (
        <div class="mb-8">
          <div class="flex items-center gap-3 mb-4">
            <span class="font-display font-bold text-lg text-blue-600">Session {year}</span>
            <div class="h-px flex-1 bg-blue-100"></div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {items.map(sujet => (
              <a
                href={`${BASE_URL}${sujet.url}`}
                target="_blank"
                rel="noopener noreferrer"
                class="group block bg-white rounded-3xl p-5 shadow-sm border border-gray-100 hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
                style="border-left: 4px solid #3b82f6;"
              >
                <div class="flex items-start justify-between gap-3">
                  <h3 class="font-display font-semibold text-sm leading-snug group-hover:text-blue-600 text-gray-700 transition-colors">
                    {sujet.title}
                  </h3>
                  <span class="shrink-0 inline-flex items-center justify-center w-8 h-8 rounded-full bg-blue-50 text-blue-500 group-hover:bg-blue-500 group-hover:text-white transition-colors">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                  </span>
                </div>
                <span class="inline-block mt-2 badge text-[10px] bg-blue-50 text-blue-600">
                  {sujet.session}
                </span>
                <div class="flex items-center gap-1.5 mt-3 text-xs font-medium text-blue-500">
                  <span>Telecharger le PDF</span>
                  <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- ============================================= -->
    <!-- MSDGN -->
    <!-- ============================================= -->
    <div class="mb-12">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-pink-500 to-pink-600 flex items-center justify-center shadow-md">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
        </div>
        <h2 class="font-display font-extrabold text-2xl">MSDGN</h2>
        <span class="badge bg-pink-100 text-pink-700 text-xs">{msdgn.length} sujets</span>
        <div class="h-px flex-1 bg-gray-200"></div>
      </div>

      {msdgnByYear.map(({ year, items }) => (
        <div class="mb-8">
          <div class="flex items-center gap-3 mb-4">
            <span class="font-display font-bold text-lg text-pink-600">Session {year}</span>
            <div class="h-px flex-1 bg-pink-100"></div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {items.map(sujet => (
              <a
                href={`${BASE_URL}${sujet.url}`}
                target="_blank"
                rel="noopener noreferrer"
                class="group block bg-white rounded-3xl p-5 shadow-sm border border-gray-100 hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
                style="border-left: 4px solid #ec4899;"
              >
                <div class="flex items-start justify-between gap-3">
                  <h3 class="font-display font-semibold text-sm leading-snug group-hover:text-pink-600 text-gray-700 transition-colors">
                    {sujet.title}
                  </h3>
                  <span class="shrink-0 inline-flex items-center justify-center w-8 h-8 rounded-full bg-pink-50 text-pink-500 group-hover:bg-pink-500 group-hover:text-white transition-colors">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                  </span>
                </div>
                <span class="inline-block mt-2 badge text-[10px] bg-pink-50 text-pink-600">
                  {sujet.session}
                </span>
                <div class="flex items-center gap-1.5 mt-3 text-xs font-medium text-pink-500">
                  <span>Telecharger le PDF</span>
                  <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Source -->
    <div class="glass rounded-2xl p-5 text-center text-sm text-gray-500 mb-8">
      <p>Tous les sujets proviennent du <a href="https://crcom.ac-versailles.fr/" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:text-blue-700 underline font-medium">CRCOM - Academie de Versailles</a>.</p>
    </div>

    <!-- CTA bottom -->
    <div class="text-center mt-8">
      <a href="/outils" class="btn-primary inline-flex items-center gap-2 px-6 py-3">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Retour aux outils
      </a>
    </div>

  </section>

</Layout>
