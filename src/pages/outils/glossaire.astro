---
import Layout from '../../layouts/Layout.astro';
import Glossaire from '../../components/Glossaire';
import { subjects } from '../../data/subjects';
import { flashcards } from '../../data/flashcards';

// Build glossary entries from all flashcard data
const entries = [];
for (const subject of subjects.filter(s => s.available)) {
  for (const chapter of subject.chapters) {
    const set = flashcards[chapter.slug];
    if (set) {
      for (const card of set.cards) {
        entries.push({
          term: card.term,
          definition: card.definition,
          example: card.example,
          subject: subject.shortName,
          subjectColor: subject.colorHex,
          chapter: chapter.title,
        });
      }
    }
  }
}
// Sort alphabetically
entries.sort((a, b) => a.term.localeCompare(b.term, 'fr'));

const totalTerms = entries.length;
const totalSubjects = new Set(entries.map(e => e.subject)).size;
---

<Layout title="📖 Glossaire STMG">

  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-10 text-center">
      <nav class="flex items-center justify-center gap-2 text-sm text-gray-400 mb-6">
        <a href="/" class="hover:text-gray-600 transition-colors">Accueil</a>
        <span>/</span>
        <a href="/outils" class="hover:text-gray-600 transition-colors">Outils</a>
        <span>/</span>
        <span class="text-gray-600">Glossaire</span>
      </nav>

      <div class="inline-flex items-center justify-center w-16 h-16 rounded-3xl bg-gradient-to-br from-blue-500 to-violet-600 shadow-xl mb-6">
        <span class="text-3xl">📖</span>
      </div>
      <h1 class="font-display font-extrabold text-3xl sm:text-4xl">Glossaire STMG</h1>
      <p class="text-gray-500 mt-3 max-w-lg mx-auto">
        Tous les termes essentiels du programme STMG, classes par ordre alphabetique. Recherche, filtre par matiere et navigation rapide.
      </p>

      <!-- Stats -->
      <div class="flex items-center justify-center gap-6 mt-6">
        <div class="flex items-center gap-2 px-4 py-2 rounded-xl bg-white border border-gray-100 shadow-sm">
          <span class="text-2xl">📚</span>
          <div class="text-left">
            <p class="text-xs text-gray-400 font-medium">Termes</p>
            <p class="font-display font-bold text-gray-900">{totalTerms}</p>
          </div>
        </div>
        <div class="flex items-center gap-2 px-4 py-2 rounded-xl bg-white border border-gray-100 shadow-sm">
          <span class="text-2xl">🎓</span>
          <div class="text-left">
            <p class="text-xs text-gray-400 font-medium">Matieres</p>
            <p class="font-display font-bold text-gray-900">{totalSubjects}</p>
          </div>
        </div>
      </div>
    </div>

    <Glossaire client:load entries={entries} />
  </section>

</Layout>
