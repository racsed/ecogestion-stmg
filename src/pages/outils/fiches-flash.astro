---
import Layout from '../../layouts/Layout.astro';
import { subjects } from '../../data/subjects';
import { flashcards } from '../../data/flashcards';

const availableSubjects = subjects.filter(s => s.available);

// Build a list of subjects with their chapters that have flashcards
const subjectsWithFlash = availableSubjects.map(s => ({
  ...s,
  flashChapters: s.chapters.filter(ch => flashcards[ch.slug]),
})).filter(s => s.flashChapters.length > 0);

const totalSets = subjectsWithFlash.reduce((acc, s) => acc + s.flashChapters.length, 0);
const totalCards = Object.values(flashcards).reduce((acc, set) => acc + set.cards.length, 0);

const getSubjectPath = (s: typeof availableSubjects[0]) => {
  const name = s.id.replace(`-${s.level}`, '');
  return `/${s.level}/${name}`;
};

const levelLabel = (level: string) => level === 'premiere' ? 'Premiere' : 'Terminale';

// Group subjects by level
const premiereSubjects = subjectsWithFlash.filter(s => s.level === 'premiere');
const terminaleSubjects = subjectsWithFlash.filter(s => s.level === 'terminale');
---

<Layout title="🃏 Fiches Flash - Revision STMG">

  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Breadcrumb -->
    <nav class="flex items-center justify-center gap-2 text-sm text-gray-400 mb-8">
      <a href="/" class="hover:text-gray-600 transition-colors">Accueil</a>
      <span>/</span>
      <a href="/outils" class="hover:text-gray-600 transition-colors">Outils</a>
      <span>/</span>
      <span class="text-gray-600">Fiches Flash</span>
    </nav>

    <!-- Hero -->
    <div class="text-center mb-14">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-3xl bg-gradient-to-br from-violet-500 to-fuchsia-500 shadow-xl mb-6">
        <span class="text-3xl">🃏</span>
      </div>
      <h1 class="font-display font-extrabold text-3xl sm:text-4xl mb-3">Fiches Flash</h1>
      <p class="text-gray-500 max-w-lg mx-auto mb-8">
        Revise tes notions cle avec des cartes recto/verso interactives. Choisis un chapitre et teste tes connaissances.
      </p>

      <!-- Stats -->
      <div class="flex items-center justify-center gap-6">
        <div class="glass rounded-2xl px-5 py-3 text-center">
          <p class="font-display font-extrabold text-2xl gradient-text">{totalSets}</p>
          <p class="text-xs text-gray-500 mt-0.5">chapitres</p>
        </div>
        <div class="glass rounded-2xl px-5 py-3 text-center">
          <p class="font-display font-extrabold text-2xl gradient-text">{totalCards}</p>
          <p class="text-xs text-gray-500 mt-0.5">cartes au total</p>
        </div>
        <div class="glass rounded-2xl px-5 py-3 text-center">
          <p class="font-display font-extrabold text-2xl gradient-text">{subjectsWithFlash.length}</p>
          <p class="text-xs text-gray-500 mt-0.5">matieres</p>
        </div>
      </div>
    </div>

    <!-- Premiere -->
    {premiereSubjects.length > 0 && (
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-6">
          <span class="badge bg-blue-100 text-blue-700">Premiere</span>
          <div class="h-px flex-1 bg-gray-200"></div>
        </div>

        <div class="space-y-10">
          {premiereSubjects.map(s => (
            <div>
              <div class="flex items-center gap-3 mb-4">
                <span class="text-2xl">{s.emoji}</span>
                <h2 class="font-display font-bold text-xl">{s.name}</h2>
                <span class="badge text-xs" style={`background: ${s.colorHex}15; color: ${s.colorHex};`}>
                  {s.flashChapters.length} {s.flashChapters.length > 1 ? 'chapitres' : 'chapitre'}
                </span>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                {s.flashChapters.map(ch => (
                  <a
                    href={`${getSubjectPath(s)}/${ch.slug}`}
                    class="group block bg-white rounded-3xl p-5 shadow-sm border border-gray-100 hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
                    style={`border-left: 4px solid ${s.colorHex};`}
                  >
                    <div class="flex items-start justify-between gap-3">
                      <h3 class="font-display font-semibold text-sm leading-snug group-hover:text-gray-900 text-gray-700">
                        {ch.title}
                      </h3>
                      <span
                        class="shrink-0 inline-flex items-center justify-center rounded-full px-2.5 py-0.5 text-xs font-bold"
                        style={`background: ${s.colorHex}15; color: ${s.colorHex};`}
                      >
                        {flashcards[ch.slug].cards.length}
                      </span>
                    </div>
                    <p class="text-xs text-gray-400 mt-2">Theme {ch.themeNumber} - {ch.theme}</p>
                    <div class="flex items-center gap-1.5 mt-3 text-xs font-medium" style={`color: ${s.colorHex};`}>
                      <span>Reviser</span>
                      <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                      </svg>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Terminale -->
    {terminaleSubjects.length > 0 && (
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-6">
          <span class="badge bg-purple-100 text-purple-700">Terminale</span>
          <div class="h-px flex-1 bg-gray-200"></div>
        </div>

        <div class="space-y-10">
          {terminaleSubjects.map(s => (
            <div>
              <div class="flex items-center gap-3 mb-4">
                <span class="text-2xl">{s.emoji}</span>
                <h2 class="font-display font-bold text-xl">{s.name}</h2>
                <span class="badge text-xs" style={`background: ${s.colorHex}15; color: ${s.colorHex};`}>
                  {s.flashChapters.length} {s.flashChapters.length > 1 ? 'chapitres' : 'chapitre'}
                </span>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                {s.flashChapters.map(ch => (
                  <a
                    href={`${getSubjectPath(s)}/${ch.slug}`}
                    class="group block bg-white rounded-3xl p-5 shadow-sm border border-gray-100 hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
                    style={`border-left: 4px solid ${s.colorHex};`}
                  >
                    <div class="flex items-start justify-between gap-3">
                      <h3 class="font-display font-semibold text-sm leading-snug group-hover:text-gray-900 text-gray-700">
                        {ch.title}
                      </h3>
                      <span
                        class="shrink-0 inline-flex items-center justify-center rounded-full px-2.5 py-0.5 text-xs font-bold"
                        style={`background: ${s.colorHex}15; color: ${s.colorHex};`}
                      >
                        {flashcards[ch.slug].cards.length}
                      </span>
                    </div>
                    <p class="text-xs text-gray-400 mt-2">Theme {ch.themeNumber} - {ch.theme}</p>
                    <div class="flex items-center gap-1.5 mt-3 text-xs font-medium" style={`color: ${s.colorHex};`}>
                      <span>Reviser</span>
                      <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                      </svg>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- CTA bottom -->
    <div class="text-center mt-8">
      <a href="/outils" class="btn-primary inline-flex items-center gap-2 px-6 py-3">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Retour aux outils
      </a>
    </div>

  </section>

</Layout>
