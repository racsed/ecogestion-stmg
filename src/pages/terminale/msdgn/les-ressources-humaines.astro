---
import Layout from '../../../layouts/Layout.astro';
import QCMEngine from '../../../components/QCMEngine';
import FichesFlash from '../../../components/FichesFlash';
import { subjects } from '../../../data/subjects';
import { allQCM } from '../../../data/allQCM';
import { flashcards } from '../../../data/flashcards';

const subject = subjects.find(s => s.id === 'msdgn-terminale')!;
const chapter = subject.chapters.find(c => c.slug === 'les-ressources-humaines')!;
const questions = allQCM['les-ressources-humaines'] || [];
const flashcardSet = flashcards['les-ressources-humaines'];

// Find previous and next chapters
const chapterIndex = subject.chapters.indexOf(chapter);
const prevChapter = chapterIndex > 0 ? subject.chapters[chapterIndex - 1] : null;
const nextChapter = chapterIndex < subject.chapters.length - 1 ? subject.chapters[chapterIndex + 1] : null;
---

<Layout title={`${chapter.title} — ${subject.name} Terminale`}>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-gray-400 mb-8 flex-wrap">
      <a href="/" class="hover:text-gray-600 transition-colors">Accueil</a>
      <span>/</span>
      <a href="/" class="hover:text-gray-600 transition-colors">Terminale</a>
      <span>/</span>
      <a href="/terminale/msdgn" class="hover:text-gray-600 transition-colors" style={`color: ${subject.colorHex};`}>{subject.name}</a>
      <span>/</span>
      <span class="text-gray-600">{chapter.title}</span>
    </nav>

    <!-- Chapter header -->
    <header class="mb-10">
      <div class="flex items-center gap-2 mb-3">
        <span class="badge text-xs" style={`background: ${subject.colorHex}15; color: ${subject.colorHex};`}>
          Thème {chapter.themeNumber}
        </span>
        <span class="badge bg-gray-100 text-gray-500 text-xs">{chapter.theme}</span>
      </div>
      <h1 class="font-display font-extrabold text-3xl sm:text-4xl leading-tight">{chapter.title}</h1>
      <div class="flex items-center gap-4 mt-4 text-sm text-gray-400">
        <span>📖 Fiche de synthèse</span>
        <span>🎯 QCM ({questions.length} questions)</span>
      </div>
    </header>

    <!-- ═══ FICHE DE SYNTHÈSE ═══ -->
    <section class="mb-16">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 rounded-2xl flex items-center justify-center" style={`background: ${subject.colorHex}15;`}>
          <span class="text-xl">📝</span>
        </div>
        <h2 class="font-display font-bold text-xl">Fiche de synthèse</h2>
      </div>

      <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-6 sm:p-8 space-y-6">

        <div class="p-5 rounded-2xl" style={`background: ${subject.colorHex}08; border-left: 4px solid ${subject.colorHex};`}>
          <h3 class="font-display font-bold text-lg mb-2" style={`color: ${subject.colorHex};`}>
            🔑 Notions essentielles
          </h3>
          <div class="flex flex-wrap gap-2 mt-3">
            {chapter.notions.map(n => (
              <span class="badge bg-white shadow-sm text-gray-700">{n}</span>
            ))}
          </div>
        </div>

        <div class="prose prose-sm max-w-none">
          <h3 class="font-display font-bold text-lg">1. La gestion prévisionnelle des emplois et des compétences (GPEC)</h3>
          <p>La <strong>GPEC</strong> est une démarche qui vise a anticiper les besoins en ressources humaines de l'organisation en fonction de sa stratégie et de l'évolution de son environnement. Elle consiste a comparer les <strong>ressources disponibles</strong> (effectifs, compétences actuelles) aux <strong>besoins futurs</strong> pour identifier les écarts et mettre en place des actions correctives.</p>
          <p>Les outils de la GPEC comprennent la <strong>cartographie des métiers</strong>, les <strong>référentiels de compétences</strong>, les <strong>entretiens annuels d'évaluation</strong> et les <strong>plans de mobilité interne</strong>. La GPEC est obligatoire dans les entreprises de plus de 300 salariés (négociation triennale). Depuis les ordonnances Macron de 2017, on parle aussi de <strong>GEPP</strong> (Gestion des Emplois et des Parcours Professionnels), qui insiste davantage sur la notion de parcours et de transitions professionnelles.</p>

          <div class="p-4 rounded-xl bg-pink-50 border border-pink-100 my-4">
            <p class="text-sm font-semibold text-pink-800 mb-1">Exemple - Decathlon</p>
            <p class="text-sm text-pink-700">Decathlon utilise la GPEC pour anticiper les besoins liés a l'ouverture de nouveaux magasins et au développement du e-commerce. L'enseigne a mis en place un référentiel de compétences pour chaque métier (vendeur, chef de rayon, ingénieur produit) et propose a ses salariés des parcours de mobilité interne : un vendeur passionné de vélo peut devenir chef de produit chez B'Twin apres une formation interne. En 2023, plus de 70 % des managers Decathlon ont été promus en interne.</p>
          </div>

          <h3 class="font-display font-bold text-lg mt-6">2. Le recrutement</h3>
          <p>Le <strong>processus de recrutement</strong> se décompose en plusieurs étapes : identification du besoin, rédaction de la fiche de poste, diffusion de l'offre, tri des candidatures, entretiens, sélection et intégration du candidat retenu.</p>
          <p>On distingue le <strong>recrutement interne</strong> (promotion, mutation) du <strong>recrutement externe</strong> (annonces, cabinets, réseaux sociaux professionnels). Le recrutement interne favorise la motivation et réduit les couts, tandis que le recrutement externe apporte des compétences nouvelles et un regard extérieur.</p>
          <p>Les outils de sélection incluent le <strong>CV</strong>, la <strong>lettre de motivation</strong>, les <strong>tests de compétences</strong>, les <strong>mises en situation</strong> et les <strong>entretiens</strong> (individuels ou collectifs). Le recrutement doit respecter le principe de <strong>non-discrimination</strong> (article L1132-1 du Code du travail).</p>
          <p>L'essor du numérique a profondément transformé les pratiques de recrutement : les entreprises utilisent désormais les <strong>réseaux sociaux professionnels</strong> (LinkedIn), les <strong>jobboards</strong> (Indeed, Welcome to the Jungle), les <strong>ATS</strong> (logiciels de suivi des candidatures) et meme l'<strong>intelligence artificielle</strong> pour le tri des CV. L'<strong>onboarding</strong> (intégration du nouveau salarié) est devenu un enjeu stratégique pour réduire le turnover des premieres semaines.</p>

          <div class="p-4 rounded-xl bg-pink-50 border border-pink-100 my-4">
            <p class="text-sm font-semibold text-pink-800 mb-1">Exemple - OVHcloud</p>
            <p class="text-sm text-pink-700">OVHcloud recrute chaque année plusieurs centaines de développeurs et ingénieurs dans un marché du travail tres tendu pour les profils tech. L'entreprise a développé une <strong>marque employeur</strong> forte en mettant en avant ses valeurs (souveraineté numérique, innovation Made in France) et propose un processus de recrutement en trois étapes : un test technique en ligne, un entretien avec un pair technique, puis un entretien de motivation. OVHcloud mise aussi sur l'alternance, avec plus de 200 alternants accueillis chaque année.</p>
          </div>

          <h3 class="font-display font-bold text-lg mt-6">3. La formation professionnelle</h3>
          <p>La formation est un levier essentiel de la GRH. Le <strong>plan de développement des compétences</strong> (ex-plan de formation) regroupe les actions de formation décidées par l'employeur pour adapter les salariés a leur poste ou développer leurs compétences.</p>
          <p>Le <strong>Compte Personnel de Formation (CPF)</strong> permet a chaque actif d'accumuler des droits a la formation tout au long de sa carriere (500 euros par an, plafond de 5 000 euros). La formation peut aussi passer par l'<strong>alternance</strong> (contrat d'apprentissage, contrat de professionnalisation) ou la <strong>VAE</strong> (Validation des Acquis de l'Expérience).</p>
          <p>La formation répond a un double enjeu : pour l'<strong>entreprise</strong>, elle permet de maintenir la compétitivité, d'accompagner les mutations technologiques et d'adapter les compétences a la stratégie. Pour le <strong>salarié</strong>, elle favorise l'employabilité, l'évolution de carriere et l'épanouissement professionnel. C'est un investissement immatériel qui génere de la <strong>valeur a long terme</strong>.</p>

          <div class="p-4 rounded-xl bg-pink-50 border border-pink-100 my-4">
            <p class="text-sm font-semibold text-pink-800 mb-1">Exemple - BlaBlaCar</p>
            <p class="text-sm text-pink-700">BlaBlaCar a mis en place un programme de formation continue appelé "BlaBlaLearn" qui permet a chaque salarié de consacrer un budget annuel a des formations de son choix (en ligne ou en présentiel). L'entreprise organise aussi des "Tech Talks" hebdomadaires ou les développeurs partagent leurs connaissances entre pairs. Cette culture de l'apprentissage continu permet a BlaBlaCar de retenir ses talents dans un secteur tres compétitif.</p>
          </div>

          <h3 class="font-display font-bold text-lg mt-6">4. La motivation et la rémunération</h3>
          <p>La <strong>motivation</strong> des salariés est un enjeu central du management. Deux théories sont incontournables au bac :</p>
          <ul>
            <li><strong>Abraham Maslow</strong> : la pyramide des besoins hiérarchise cinq niveaux (physiologiques, sécurité, appartenance, estime, accomplissement). Un besoin satisfait ne motive plus ; c'est le besoin du niveau supérieur qui prend le relais comme source de motivation.</li>
            <li><strong>Frederick Herzberg</strong> : la théorie bi-factorielle distingue les <strong>facteurs d'hygiene</strong> (salaire, conditions de travail, sécurité de l'emploi) qui évitent l'insatisfaction, et les <strong>facteurs de motivation</strong> (reconnaissance, responsabilités, autonomie, contenu du travail) qui générent la satisfaction. Point clé : améliorer les facteurs d'hygiene ne crée pas de motivation, cela supprime seulement l'insatisfaction.</li>
          </ul>
          <p>La <strong>rémunération</strong> est un outil de motivation qui comprend une part <strong>fixe</strong> (salaire de base) et une part <strong>variable</strong> (primes, commissions, intéressement, participation). S'y ajoutent les <strong>avantages en nature</strong> (voiture de fonction, tickets restaurant) et l'<strong>épargne salariale</strong> (PEE, PERCO).</p>

          <div class="p-4 rounded-xl bg-pink-50 border border-pink-100 my-4">
            <p class="text-sm font-semibold text-pink-800 mb-1">Exemple - Decathlon (motivation)</p>
            <p class="text-sm text-pink-700">Decathlon applique les principes de Herzberg en combinant des facteurs d'hygiene solides (rémunération compétitive, intéressement généreux - en 2022, chaque salarié a touché en moyenne 2 mois de salaire supplémentaires via l'intéressement) et des facteurs de motivation forts (autonomie dans la gestion du rayon, responsabilisation précoce des jeunes recrues, possibilité de tester les produits qu'ils vendent). La "passion sportive" est au coeur de la culture d'entreprise et nourrit le besoin d'accomplissement (Maslow).</p>
          </div>

          <h3 class="font-display font-bold text-lg mt-6">5. Le climat social et les conditions de travail</h3>
          <p>Le <strong>climat social</strong> désigne l'ambiance générale qui regne au sein d'une organisation. Il est influencé par la qualité des relations entre salariés et direction, les conditions de travail, le niveau de rémunération et le sentiment de justice. Un mauvais climat social se traduit par un <strong>taux d'absentéisme</strong> élevé, un <strong>turnover</strong> important et une baisse de la productivité.</p>
          <p>Les <strong>conditions de travail</strong> englobent l'environnement physique (bruit, ergonomie, sécurité), l'organisation du travail (horaires, charge de travail, autonomie) et les relations sociales (ambiance, management, reconnaissance). La <strong>Qualité de Vie et des Conditions de Travail (QVCT)</strong>, anciennement QVT, est devenue un enjeu stratégique majeur. Elle inclut le droit a la déconnexion, la prévention des <strong>risques psychosociaux</strong> (RPS : stress, burn-out, harcelement) et l'équilibre vie professionnelle / vie personnelle.</p>

          <div class="p-4 rounded-xl bg-pink-50 border border-pink-100 my-4">
            <p class="text-sm font-semibold text-pink-800 mb-1">Exemple - Michel et Augustin</p>
            <p class="text-sm text-pink-700">Michel et Augustin cultive un climat social positif grace a une culture d'entreprise originale : les bureaux sont baptisés "la Bananeraie", les salariés participent a des ateliers cuisine, et chaque mois l'entreprise ouvre ses portes pour des recrutements "a la bonne franquette". Le tutoiement est la regle, y compris avec les dirigeants. Cette approche favorise le sentiment d'appartenance (Maslow, niveau 3) et contribue a un turnover particulierement bas pour une PME du secteur agroalimentaire.</p>
          </div>

          <h3 class="font-display font-bold text-lg mt-6">6. Le dialogue social</h3>
          <p>Le <strong>dialogue social</strong> désigne l'ensemble des discussions et négociations entre l'employeur et les représentants des salariés. Il se structure autour de plusieurs instances :</p>
          <ul>
            <li>Le <strong>CSE</strong> (Comité Social et Économique), obligatoire dans les entreprises de plus de 11 salariés, qui regroupe les anciennes instances (DP, CE, CHSCT).</li>
            <li>Les <strong>délégués syndicaux</strong>, qui négocient les accords d'entreprise (salaires, temps de travail, égalité professionnelle).</li>
            <li>Les <strong>négociations annuelles obligatoires (NAO)</strong> sur les rémunérations, le temps de travail et le partage de la valeur ajoutée.</li>
          </ul>
          <p>Un dialogue social de qualité permet de prévenir les conflits, d'améliorer les conditions de travail et de faire évoluer l'organisation de maniere concertée. Les <strong>conflits sociaux</strong> (greves, débrayages) sont le signe d'un dialogue social défaillant.</p>
        </div>

        <div class="p-5 rounded-2xl bg-blue-50 border border-blue-100 mb-4">
          <h4 class="font-display font-bold text-sm text-blue-800 mb-2">Transversalités</h4>
          <ul class="text-sm text-blue-700 space-y-1">
            <li><strong>Droit</strong> : le contrat de travail (CDI, CDD, intérim), la non-discrimination a l'embauche, le droit de greve, le CSE, les conventions collectives.</li>
            <li><strong>Économie</strong> : le marché du travail (offre/demande de travail, chomage), le cout du travail et la compétitivité, les politiques de l'emploi.</li>
            <li><strong>Management 1re</strong> : les styles de direction (Likert), la prise de décision, la culture d'entreprise et son influence sur la GRH.</li>
          </ul>
        </div>

        <div class="p-5 rounded-2xl bg-amber-50 border border-amber-100">
          <h4 class="font-display font-bold text-sm text-amber-800 mb-2">A retenir pour l'examen</h4>
          <ul class="text-sm text-amber-700 space-y-1">
            <li><strong>Maslow et Herzberg</strong> sont les auteurs les plus fréquents au bac STMG en MSDGN. Vous devez connaitre leurs théories par coeur et savoir les appliquer a un cas concret.</li>
            <li>Attention au piege classique chez Herzberg : un bon salaire ne motive pas, il empeche simplement l'insatisfaction. Pour motiver, il faut agir sur le contenu du travail (responsabilités, reconnaissance, autonomie).</li>
            <li>Quand le sujet porte sur le recrutement, pensez a comparer recrutement interne et externe en précisant les avantages et limites de chaque option.</li>
            <li>La GPEC/GEPP est souvent liée a un contexte de transformation (numérique, concurrence, restructuration) : montrez comment elle anticipe les besoins futurs.</li>
            <li>N'oubliez pas les <strong>indicateurs sociaux</strong> : taux de turnover, taux d'absentéisme, climat social. Ils sont souvent présents dans les annexes du sujet.</li>
            <li>Pensez a évoquer le CSE et le dialogue social si le sujet mentionne des tensions ou des négociations entre salariés et direction.</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ═══ QCM ═══ -->
    {questions.length > 0 && (
      <section class="mb-16">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-2xl flex items-center justify-center" style={`background: ${subject.colorHex}15;`}>
            <span class="text-xl">🎯</span>
          </div>
          <h2 class="font-display font-bold text-xl">QCM — Teste tes connaissances</h2>
          <span class="badge text-xs" style={`background: ${subject.colorHex}15; color: ${subject.colorHex};`}>
            {questions.length} questions
          </span>
        </div>

        <QCMEngine
          client:load
          questions={questions}
          subjectColor={subject.colorHex}
          chapterTitle={chapter.title}
        />
      </section>
    )}

    <!-- ═══ FICHES FLASH ═══ -->
    {flashcardSet && (
      <section class="mb-16">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-2xl flex items-center justify-center" style={`background: ${subject.colorHex}15;`}>
            <span class="text-xl">⚡</span>
          </div>
          <h2 class="font-display font-bold text-xl">Fiches Flash</h2>
          <span class="badge text-xs" style={`background: ${subject.colorHex}15; color: ${subject.colorHex};`}>
            {flashcardSet.cards.length} notions
          </span>
        </div>

        <FichesFlash
          client:load
          cards={flashcardSet.cards}
          subjectColor={subject.colorHex}
          title={chapter.title}
        />
      </section>
    )}

    <!-- ═══ NAVIGATION ═══ -->
    <nav class="flex items-center justify-between pt-8 border-t border-gray-100">
      {prevChapter ? (
        <a href={`/terminale/msdgn/${prevChapter.slug}`} class="flex items-center gap-3 group text-sm text-gray-500 hover:text-gray-800 transition-colors">
          <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
          <div>
            <span class="text-xs text-gray-400">Précédent</span>
            <p class="font-medium">{prevChapter.title}</p>
          </div>
        </a>
      ) : <div />}

      {nextChapter ? (
        <a href={`/terminale/msdgn/${nextChapter.slug}`} class="flex items-center gap-3 group text-sm text-gray-500 hover:text-gray-800 transition-colors text-right">
          <div>
            <span class="text-xs text-gray-400">Suivant</span>
            <p class="font-medium">{nextChapter.title}</p>
          </div>
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
      ) : <div />}
    </nav>

  </div>

</Layout>
