---
import Layout from '../../../layouts/Layout.astro';
import { subjects } from '../../../data/subjects';

const subject = subjects.find(s => s.id === 'economie-terminale')!;

const themes = subject.chapters.reduce((acc, ch) => {
  if (!acc[ch.themeNumber]) {
    acc[ch.themeNumber] = { title: ch.theme, chapters: [] };
  }
  acc[ch.themeNumber].chapters.push(ch);
  return acc;
}, {} as Record<number, { title: string; chapters: typeof subject.chapters }>);
---

<Layout title={`${subject.emoji} ${subject.name} — Terminale STMG`}>
  
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.07]" style={`background: linear-gradient(135deg, ${subject.gradientFrom}, ${subject.gradientTo});`}></div>
    
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-10 relative">
      <nav class="flex items-center gap-2 text-sm text-gray-400 mb-6">
        <a href="/" class="hover:text-gray-600 transition-colors">Accueil</a>
        <span>/</span>
        <a href="/" class="hover:text-gray-600 transition-colors">Terminale</a>
        <span>/</span>
        <span style={`color: ${subject.colorHex}`}>{subject.name}</span>
      </nav>

      <div class="flex items-start gap-5">
        <div class="w-16 h-16 rounded-3xl flex items-center justify-center shadow-xl text-3xl"
             style={`background: linear-gradient(135deg, ${subject.gradientFrom}, ${subject.gradientTo});`}>
          <span class="filter drop-shadow">{subject.emoji}</span>
        </div>
        <div>
          <div class="flex items-center gap-3">
            <h1 class="font-display font-extrabold text-3xl sm:text-4xl">{subject.name}</h1>
            <span class="badge text-xs" style={`background: ${subject.colorHex}15; color: ${subject.colorHex};`}>Terminale</span>
          </div>
          <p class="text-gray-500 mt-2 text-lg">{subject.description}</p>
          <div class="flex items-center gap-3 mt-3">
            <span class="text-sm text-gray-400">
              📖 {subject.chapters.length} chapitres · 
              🎯 {subject.chapters.filter(c => c.hasQCM).length} QCM · 
              📄 {subject.chapters.filter(c => c.hasSujet).length} sujets de bac
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    {!subject.available ? (
      <div class="text-center py-20">
        <span class="text-6xl mb-6 block">🚧</span>
        <h2 class="font-display font-bold text-2xl mb-2">Bientôt disponible</h2>
        <p class="text-gray-500 max-w-md mx-auto">Cette matière est en cours de préparation. Revenez bientôt pour découvrir les cours et QCM !</p>
      </div>
    ) : (
      <div class="space-y-12">
        {Object.entries(themes).map(([num, theme]) => (
          <div>
            <div class="flex items-center gap-3 mb-5">
              <span class="flex-shrink-0 w-8 h-8 rounded-xl flex items-center justify-center text-sm font-bold text-white"
                    style={`background: ${subject.colorHex};`}>
                {num}
              </span>
              <h2 class="font-display font-bold text-xl text-gray-800">{theme.title}</h2>
            </div>
            <div class="grid gap-4">
              {theme.chapters.map((ch, i) => (
                <div class="chapter-card flex items-center gap-4 opacity-60 cursor-default">
                  <div class="flex-shrink-0 w-10 h-10 rounded-xl flex items-center justify-center text-sm font-bold"
                       style={`background: ${subject.colorHex}10; color: ${subject.colorHex};`}>
                    {String(i + 1).padStart(2, '0')}
                  </div>
                  <div class="flex-1 min-w-0">
                    <h3 class="font-display font-semibold text-base">{ch.title}</h3>
                    <p class="text-xs text-gray-400 mt-0.5 truncate">{ch.notions.join(' · ')}</p>
                  </div>
                  <span class="badge bg-gray-100 text-gray-500 text-[10px]">Bientôt</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    )}
  </section>
</Layout>
