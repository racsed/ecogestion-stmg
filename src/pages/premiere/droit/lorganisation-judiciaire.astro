---
import Layout from '../../../layouts/Layout.astro';
import QCMEngine from '../../../components/QCMEngine';
import FichesFlash from '../../../components/FichesFlash';
import { subjects } from '../../../data/subjects';
import { allQCM } from '../../../data/allQCM';
import { flashcards } from '../../../data/flashcards';

const subject = subjects.find(s => s.id === 'droit-premiere')!;
const chapter = subject.chapters.find(c => c.slug === 'lorganisation-judiciaire')!;
const questions = allQCM['lorganisation-judiciaire'] || [];
const flashcardSet = flashcards['lorganisation-judiciaire'];

// Find previous and next chapters
const chapterIndex = subject.chapters.indexOf(chapter);
const prevChapter = chapterIndex > 0 ? subject.chapters[chapterIndex - 1] : null;
const nextChapter = chapterIndex < subject.chapters.length - 1 ? subject.chapters[chapterIndex + 1] : null;
---

<Layout title={`${chapter.title} — ${subject.name} Première`}>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-gray-400 mb-8 flex-wrap">
      <a href="/" class="hover:text-gray-600 transition-colors">Accueil</a>
      <span>/</span>
      <a href="/" class="hover:text-gray-600 transition-colors">Première</a>
      <span>/</span>
      <a href="/premiere/droit" class="hover:text-gray-600 transition-colors" style={`color: ${subject.colorHex};`}>{subject.name}</a>
      <span>/</span>
      <span class="text-gray-600">{chapter.title}</span>
    </nav>

    <!-- Chapter header -->
    <header class="mb-10">
      <div class="flex items-center gap-2 mb-3">
        <span class="badge text-xs" style={`background: ${subject.colorHex}15; color: ${subject.colorHex};`}>
          Thème {chapter.themeNumber}
        </span>
        <span class="badge bg-gray-100 text-gray-500 text-xs">{chapter.theme}</span>
      </div>
      <h1 class="font-display font-extrabold text-3xl sm:text-4xl leading-tight">{chapter.title}</h1>
      <div class="flex items-center gap-4 mt-4 text-sm text-gray-400">
        <span>📖 Fiche de synthèse</span>
        <span>🎯 QCM ({questions.length} questions)</span>
      </div>
    </header>

    <!-- ═══ FICHE DE SYNTHÈSE ═══ -->
    <section class="mb-16">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 rounded-2xl flex items-center justify-center" style={`background: ${subject.colorHex}15;`}>
          <span class="text-xl">📝</span>
        </div>
        <h2 class="font-display font-bold text-xl">Fiche de synthèse</h2>
      </div>

      <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-6 sm:p-8 space-y-6">

        <div class="p-5 rounded-2xl" style={`background: ${subject.colorHex}08; border-left: 4px solid ${subject.colorHex};`}>
          <h3 class="font-display font-bold text-lg mb-2" style={`color: ${subject.colorHex};`}>
            🔑 Notions essentielles
          </h3>
          <div class="flex flex-wrap gap-2 mt-3">
            {chapter.notions.map(n => (
              <span class="badge bg-white shadow-sm text-gray-700">{n}</span>
            ))}
          </div>
        </div>

        <div class="prose prose-sm max-w-none">
          <h3 class="font-display font-bold text-lg">1. Les deux ordres de juridiction</h3>
          <p>L'organisation judiciaire française repose sur la séparation en <strong>deux ordres</strong> :</p>
          <ul>
            <li><strong>L'ordre judiciaire</strong> traite les litiges entre personnes privées (droit civil, commercial, social) et sanctionne les infractions pénales. Il est coiffé par la <strong>Cour de cassation</strong>.</li>
            <li><strong>L'ordre administratif</strong> traite les litiges entre les particuliers et l'administration (État, collectivités, établissements publics). Il est coiffé par le <strong>Conseil d'État</strong>.</li>
          </ul>
          <p>En cas de conflit de compétence entre les deux ordres, c'est le <strong>Tribunal des conflits</strong> qui tranche.</p>

          <h3 class="font-display font-bold text-lg mt-6">2. Les principales juridictions de l'ordre judiciaire</h3>
          <p>Les juridictions du premier degré (première instance) sont spécialisées selon la nature du litige :</p>
          <ul>
            <li><strong>Le tribunal judiciaire (TJ)</strong> : juridiction de droit commun en matière civile. Il est compétent pour tous les litiges civils qui ne relèvent pas d'une juridiction spécialisée.</li>
            <li><strong>Le tribunal de commerce</strong> : composé de juges élus par les commerçants, il traite les litiges entre commerçants et les contestations relatives aux actes de commerce.</li>
            <li><strong>Le conseil de prud'hommes</strong> : juridiction paritaire (salariés et employeurs) compétente pour les litiges individuels liés au contrat de travail (licenciement, salaires, harcèlement).</li>
          </ul>

          <h3 class="font-display font-bold text-lg mt-6">3. Le double degré de juridiction</h3>
          <p>Le principe du <strong>double degré de juridiction</strong> garantit le droit de faire rejuger une affaire. Toute personne mécontente d'un jugement de première instance peut faire <strong>appel</strong> devant la <strong>cour d'appel</strong>. Celle-ci réexamine l'affaire en fait et en droit, c'est-à-dire qu'elle juge à nouveau l'ensemble du dossier.</p>
          <p>Ce principe protège les justiciables contre le risque d'erreur judiciaire et assure une meilleure qualité de la justice.</p>

          <h3 class="font-display font-bold text-lg mt-6">4. La Cour de cassation</h3>
          <p>La <strong>Cour de cassation</strong> est la plus haute juridiction de l'ordre judiciaire. Attention : elle ne rejuge pas les faits. Elle vérifie uniquement que la <strong>règle de droit a été correctement appliquée</strong> par les juges du fond (première instance et appel). Si elle constate une erreur de droit, elle « casse » la décision et renvoie l'affaire devant une autre juridiction. La Cour de cassation contribue ainsi à l'<strong>unification de la jurisprudence</strong> sur l'ensemble du territoire.</p>
        </div>

        <div class="p-5 rounded-2xl bg-amber-50 border border-amber-100">
          <h4 class="font-display font-bold text-sm text-amber-800 mb-2">💡 À retenir pour l'examen</h4>
          <p class="text-sm text-amber-700">Retenez bien la différence entre la cour d'appel (qui rejuge les faits et le droit) et la Cour de cassation (qui ne contrôle que l'application du droit). Sachez aussi associer chaque juridiction à son domaine de compétence : TJ pour le civil, prud'hommes pour le travail, tribunal de commerce pour les commerçants.</p>
        </div>
      </div>
    </section>

    <!-- ═══ QCM ═══ -->
    {questions.length > 0 && (
      <section class="mb-16">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-2xl flex items-center justify-center" style={`background: ${subject.colorHex}15;`}>
            <span class="text-xl">🎯</span>
          </div>
          <h2 class="font-display font-bold text-xl">QCM — Teste tes connaissances</h2>
          <span class="badge text-xs" style={`background: ${subject.colorHex}15; color: ${subject.colorHex};`}>
            {questions.length} questions
          </span>
        </div>

        <QCMEngine
          client:load
          questions={questions}
          subjectColor={subject.colorHex}
          chapterTitle={chapter.title}
        />
      </section>
    )}

    <!-- ═══ FICHES FLASH ═══ -->
    {flashcardSet && (
      <section class="mb-16">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-2xl flex items-center justify-center" style={`background: ${subject.colorHex}15;`}>
            <span class="text-xl">⚡</span>
          </div>
          <h2 class="font-display font-bold text-xl">Fiches Flash</h2>
          <span class="badge text-xs" style={`background: ${subject.colorHex}15; color: ${subject.colorHex};`}>
            {flashcardSet.cards.length} notions
          </span>
        </div>

        <FichesFlash
          client:load
          cards={flashcardSet.cards}
          subjectColor={subject.colorHex}
          title={chapter.title}
        />
      </section>
    )}

    <!-- ═══ NAVIGATION ═══ -->
    <nav class="flex items-center justify-between pt-8 border-t border-gray-100">
      {prevChapter ? (
        <a href={`/premiere/droit/${prevChapter.slug}`} class="flex items-center gap-3 group text-sm text-gray-500 hover:text-gray-800 transition-colors">
          <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
          <div>
            <span class="text-xs text-gray-400">Précédent</span>
            <p class="font-medium">{prevChapter.title}</p>
          </div>
        </a>
      ) : <div />}

      {nextChapter ? (
        <a href={`/premiere/droit/${nextChapter.slug}`} class="flex items-center gap-3 group text-sm text-gray-500 hover:text-gray-800 transition-colors text-right">
          <div>
            <span class="text-xs text-gray-400">Suivant</span>
            <p class="font-medium">{nextChapter.title}</p>
          </div>
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
      ) : <div />}
    </nav>

  </div>

</Layout>
