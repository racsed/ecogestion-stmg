---
import Layout from '../../../layouts/Layout.astro';
import QCMEngine from '../../../components/QCMEngine';
import FichesFlash from '../../../components/FichesFlash';
import { subjects } from '../../../data/subjects';
import { allQCM } from '../../../data/allQCM';
import { flashcards } from '../../../data/flashcards';

const subject = subjects.find(s => s.id === 'droit-premiere')!;
const chapter = subject.chapters.find(c => c.slug === 'les-droits-extrapatrimoniaux')!;
const questions = allQCM['les-droits-extrapatrimoniaux'] || [];
const flashcardSet = flashcards['les-droits-extrapatrimoniaux'];

// Find previous and next chapters
const chapterIndex = subject.chapters.indexOf(chapter);
const prevChapter = chapterIndex > 0 ? subject.chapters[chapterIndex - 1] : null;
const nextChapter = chapterIndex < subject.chapters.length - 1 ? subject.chapters[chapterIndex + 1] : null;
---

<Layout title={`${chapter.title} — ${subject.name} Première`}>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-gray-400 mb-8 flex-wrap">
      <a href="/" class="hover:text-gray-600 transition-colors">Accueil</a>
      <span>/</span>
      <a href="/" class="hover:text-gray-600 transition-colors">Première</a>
      <span>/</span>
      <a href="/premiere/droit" class="hover:text-gray-600 transition-colors" style={`color: ${subject.colorHex};`}>{subject.name}</a>
      <span>/</span>
      <span class="text-gray-600">{chapter.title}</span>
    </nav>

    <!-- Chapter header -->
    <header class="mb-10">
      <div class="flex items-center gap-2 mb-3">
        <span class="badge text-xs" style={`background: ${subject.colorHex}15; color: ${subject.colorHex};`}>
          Thème {chapter.themeNumber}
        </span>
        <span class="badge bg-gray-100 text-gray-500 text-xs">{chapter.theme}</span>
      </div>
      <h1 class="font-display font-extrabold text-3xl sm:text-4xl leading-tight">{chapter.title}</h1>
      <div class="flex items-center gap-4 mt-4 text-sm text-gray-400">
        <span>📖 Fiche de synthèse</span>
        <span>🎯 QCM ({questions.length} questions)</span>
      </div>
    </header>

    <!-- ═══ FICHE DE SYNTHÈSE ═══ -->
    <section class="mb-16">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 rounded-2xl flex items-center justify-center" style={`background: ${subject.colorHex}15;`}>
          <span class="text-xl">📝</span>
        </div>
        <h2 class="font-display font-bold text-xl">Fiche de synthèse</h2>
      </div>

      <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-6 sm:p-8 space-y-6">

        <div class="p-5 rounded-2xl" style={`background: ${subject.colorHex}08; border-left: 4px solid ${subject.colorHex};`}>
          <h3 class="font-display font-bold text-lg mb-2" style={`color: ${subject.colorHex};`}>
            🔑 Notions essentielles
          </h3>
          <div class="flex flex-wrap gap-2 mt-3">
            {chapter.notions.map(n => (
              <span class="badge bg-white shadow-sm text-gray-700">{n}</span>
            ))}
          </div>
        </div>

        <div class="prose prose-sm max-w-none">
          <h3 class="font-display font-bold text-lg">1. Définition et caractères des droits extrapatrimoniaux</h3>
          <p>Les <strong>droits extrapatrimoniaux</strong> sont des droits attachés à la personne et qui n'ont pas de valeur pécuniaire (monétaire). Ils protègent l'intégrité physique et morale de l'individu. Ils présentent trois caractères fondamentaux :</p>
          <ul>
            <li><strong>Incessibles</strong> : ils ne peuvent pas être vendus ni cédés à un tiers.</li>
            <li><strong>Imprescriptibles</strong> : ils ne se perdent pas avec le temps, même si on ne les exerce pas.</li>
            <li><strong>Intransmissibles</strong> : ils ne peuvent pas être transmis aux héritiers (ils s'éteignent avec la personne).</li>
          </ul>
          <p>Ces caractères les distinguent radicalement des droits patrimoniaux, qui eux sont évaluables en argent.</p>

          <h3 class="font-display font-bold text-lg mt-6">2. Les droits de la personnalité</h3>
          <p>Les <strong>droits de la personnalité</strong> constituent la catégorie principale des droits extrapatrimoniaux. Ils comprennent :</p>
          <ul>
            <li><strong>Le droit au respect de la vie privée</strong> (article 9 du Code civil) : chacun a droit à la protection de sa vie sentimentale, familiale, de son domicile, de sa correspondance et de son état de santé.</li>
            <li><strong>Le droit à l'image</strong> : toute personne peut s'opposer à la captation, la reproduction et la diffusion de son image sans son consentement.</li>
            <li><strong>Le droit à l'honneur et à la réputation</strong> : la diffamation (allégation d'un fait portant atteinte à l'honneur) et l'injure sont sanctionnées par la loi.</li>
            <li><strong>Le droit à l'intégrité physique</strong> : le corps humain est inviolable. Nul ne peut porter atteinte au corps d'autrui sans nécessité médicale et sans consentement.</li>
          </ul>

          <h3 class="font-display font-bold text-lg mt-6">3. Le droit à la dignité humaine</h3>
          <p>Le <strong>droit à la dignité humaine</strong> est un droit fondamental à valeur constitutionnelle. Il interdit tout traitement dégradant, inhumain ou humiliant. Ce droit se manifeste dans plusieurs domaines :</p>
          <ul>
            <li><strong>Interdiction de l'esclavage et du travail forcé</strong> : toute forme de servitude est prohibée.</li>
            <li><strong>Protection du corps humain</strong> : le corps humain est inviolable (article 16 du Code civil). Il ne peut faire l'objet d'un droit patrimonial (on ne peut pas le vendre). Les dons d'organes reposent sur le principe de gratuité et d'anonymat.</li>
            <li><strong>Respect de la personne après le décès</strong> : le respect du à la personne ne cesse pas avec la mort. Les proches peuvent agir en justice pour protéger la mémoire du défunt.</li>
            <li><strong>Lutte contre les discriminations</strong> : toute distinction fondée sur l'origine, le sexe, l'orientation sexuelle, le handicap, l'âge ou les convictions religieuses constitue une discrimination interdite par la loi.</li>
          </ul>

          <h3 class="font-display font-bold text-lg mt-6">4. La protection des données personnelles et le RGPD</h3>
          <p>Avec le développement du numérique, la protection des <strong>données personnelles</strong> est devenue un enjeu majeur. Le <strong>Règlement Général sur la Protection des Données (RGPD)</strong>, en vigueur depuis 2018, encadre la collecte et le traitement des données dans toute l'Union européenne.</p>

          <h4 class="font-display font-semibold mt-4">Les 6 principes du RGPD</h4>
          <p>Tout traitement de données personnelles doit respecter six principes fondamentaux :</p>
          <ol>
            <li><strong>Licéité, loyauté et transparence</strong> : le traitement doit reposer sur une base légale (consentement, contrat, obligation légale) et la personne doit être informée de manière claire.</li>
            <li><strong>Limitation des finalités</strong> : les données ne peuvent être collectées que pour des finalités déterminées, explicites et légitimes. Elles ne doivent pas être réutilisées pour un objectif incompatible.</li>
            <li><strong>Minimisation des données</strong> : seules les données strictement nécessaires à la finalité déclarée doivent être collectées. On ne peut pas collecter « au cas où ».</li>
            <li><strong>Exactitude</strong> : les données doivent être exactes et tenues à jour. Les données inexactes doivent être rectifiées ou effacées sans délai.</li>
            <li><strong>Limitation de la conservation</strong> : les données ne doivent pas être conservées au-delà de la durée nécessaire à la finalité du traitement. Passé ce délai, elles doivent être supprimées ou anonymisées.</li>
            <li><strong>Intégrité et confidentialité</strong> : le responsable du traitement doit garantir la sécurité des données (protection contre les accès non autorisés, les pertes ou les destructions).</li>
          </ol>

          <h4 class="font-display font-semibold mt-4">Les droits des personnes</h4>
          <p>Le RGPD garantit plusieurs droits aux individus :</p>
          <ul>
            <li><strong>Le droit d'accès</strong> : savoir quelles données sont collectées sur soi.</li>
            <li><strong>Le droit de rectification</strong> : corriger des données inexactes.</li>
            <li><strong>Le droit à l'effacement</strong> (« droit à l'oubli ») : demander la suppression de ses données.</li>
            <li><strong>Le droit à la portabilité</strong> : récupérer ses données dans un format exploitable.</li>
            <li><strong>Le droit d'opposition</strong> : refuser le traitement de ses données, notamment à des fins de prospection commerciale.</li>
          </ul>

          <h3 class="font-display font-bold text-lg mt-6">5. Le rôle de la CNIL</h3>
          <p>La <strong>CNIL</strong> (Commission nationale de l'informatique et des libertés) est l'autorité administrative indépendante chargée de veiller au respect de la protection des données personnelles en France. Ses missions sont multiples :</p>
          <ul>
            <li><strong>Informer et conseiller</strong> : la CNIL publie des guides et des recommandations à destination des entreprises, des administrations et des particuliers pour les aider à se conformer au RGPD.</li>
            <li><strong>Contrôler</strong> : elle peut effectuer des contrôles (sur place, en ligne ou sur pièces) pour vérifier que les organismes respectent leurs obligations en matière de protection des données.</li>
            <li><strong>Sanctionner</strong> : en cas de manquement, la CNIL peut prononcer des sanctions financières pouvant atteindre 20 millions d'euros ou 4 % du chiffre d'affaires mondial annuel de l'entreprise, le montant le plus élevé étant retenu.</li>
            <li><strong>Recevoir les plaintes</strong> : toute personne peut saisir la CNIL si elle estime que ses droits en matière de données personnelles ne sont pas respectés.</li>
          </ul>
        </div>

        <div class="p-5 rounded-2xl bg-blue-50 border border-blue-100">
          <h4 class="font-display font-bold text-sm text-blue-800 mb-2">🔗 Transversalités</h4>
          <ul class="text-sm text-blue-700 space-y-1">
            <li><strong>Économie :</strong> la protection des données personnelles encadre les pratiques des entreprises du numérique (publicité ciblée, collecte massive de données) et influence les modèles économiques fondés sur l'exploitation des données.</li>
            <li><strong>Management :</strong> les organisations doivent intégrer la conformité au RGPD dans leur stratégie (désignation d'un DPO, registre des traitements, analyse d'impact) et former leurs salariés à la protection des données.</li>
          </ul>
        </div>

        <div class="p-5 rounded-2xl bg-amber-50 border border-amber-100">
          <h4 class="font-display font-bold text-sm text-amber-800 mb-2">💡 À retenir pour l'examen</h4>
          <p class="text-sm text-amber-700">Retenez les trois caractères des droits extrapatrimoniaux (incessibles, imprescriptibles, intransmissibles) et les 6 principes du RGPD. Sachez expliquer le rôle de la CNIL et le droit à la dignité humaine. Le RGPD et les droits numériques tombent très régulièrement au bac.</p>
        </div>
      </div>
    </section>

    <!-- ═══ QCM ═══ -->
    {questions.length > 0 && (
      <section class="mb-16">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-2xl flex items-center justify-center" style={`background: ${subject.colorHex}15;`}>
            <span class="text-xl">🎯</span>
          </div>
          <h2 class="font-display font-bold text-xl">QCM — Teste tes connaissances</h2>
          <span class="badge text-xs" style={`background: ${subject.colorHex}15; color: ${subject.colorHex};`}>
            {questions.length} questions
          </span>
        </div>

        <QCMEngine
          client:load
          questions={questions}
          subjectColor={subject.colorHex}
          chapterTitle={chapter.title}
        />
      </section>
    )}

    <!-- ═══ FICHES FLASH ═══ -->
    {flashcardSet && (
      <section class="mb-16">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-2xl flex items-center justify-center" style={`background: ${subject.colorHex}15;`}>
            <span class="text-xl">⚡</span>
          </div>
          <h2 class="font-display font-bold text-xl">Fiches Flash</h2>
          <span class="badge text-xs" style={`background: ${subject.colorHex}15; color: ${subject.colorHex};`}>
            {flashcardSet.cards.length} notions
          </span>
        </div>

        <FichesFlash
          client:load
          cards={flashcardSet.cards}
          subjectColor={subject.colorHex}
          title={chapter.title}
        />
      </section>
    )}

    <!-- ═══ NAVIGATION ═══ -->
    <nav class="flex items-center justify-between pt-8 border-t border-gray-100">
      {prevChapter ? (
        <a href={`/premiere/droit/${prevChapter.slug}`} class="flex items-center gap-3 group text-sm text-gray-500 hover:text-gray-800 transition-colors">
          <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
          <div>
            <span class="text-xs text-gray-400">Précédent</span>
            <p class="font-medium">{prevChapter.title}</p>
          </div>
        </a>
      ) : <div />}

      {nextChapter ? (
        <a href={`/premiere/droit/${nextChapter.slug}`} class="flex items-center gap-3 group text-sm text-gray-500 hover:text-gray-800 transition-colors text-right">
          <div>
            <span class="text-xs text-gray-400">Suivant</span>
            <p class="font-medium">{nextChapter.title}</p>
          </div>
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
      ) : <div />}
    </nav>

  </div>

</Layout>
