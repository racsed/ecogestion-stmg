---
import Layout from '../../../layouts/Layout.astro';
import QCMEngine from '../../../components/QCMEngine';
import FichesFlash from '../../../components/FichesFlash';
import { subjects } from '../../../data/subjects';
import { allQCM } from '../../../data/allQCM';
import { flashcards } from '../../../data/flashcards';

const subject = subjects.find(s => s.id === 'management-premiere')!;
const chapter = subject.chapters.find(c => c.slug === 'quest-ce-que-le-management')!;
const questions = allQCM['quest-ce-que-le-management'] || [];
const flashcardSet = flashcards['quest-ce-que-le-management'];

const chapterIndex = subject.chapters.indexOf(chapter);
const prevChapter = chapterIndex > 0 ? subject.chapters[chapterIndex - 1] : null;
const nextChapter = chapterIndex < subject.chapters.length - 1 ? subject.chapters[chapterIndex + 1] : null;
---

<Layout title={`${chapter.title} — ${subject.name} Première`}>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <nav class="flex items-center gap-2 text-sm text-gray-400 mb-8 flex-wrap">
      <a href="/" class="hover:text-gray-600 transition-colors">Accueil</a>
      <span>/</span>
      <a href="/" class="hover:text-gray-600 transition-colors">Première</a>
      <span>/</span>
      <a href="/premiere/management" class="hover:text-gray-600 transition-colors" style={`color: ${subject.colorHex};`}>{subject.name}</a>
      <span>/</span>
      <span class="text-gray-600">{chapter.title}</span>
    </nav>

    <header class="mb-10">
      <div class="flex items-center gap-2 mb-3">
        <span class="badge text-xs" style={`background: ${subject.colorHex}15; color: ${subject.colorHex};`}>
          Thème {chapter.themeNumber}
        </span>
        <span class="badge bg-gray-100 text-gray-500 text-xs">{chapter.theme}</span>
      </div>
      <h1 class="font-display font-extrabold text-3xl sm:text-4xl leading-tight">{chapter.title}</h1>
      <div class="flex items-center gap-4 mt-4 text-sm text-gray-400">
        <span>📖 Fiche de synthèse</span>
        <span>🎯 QCM ({questions.length} questions)</span>
      </div>
    </header>

    <section class="mb-16">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 rounded-2xl flex items-center justify-center" style={`background: ${subject.colorHex}15;`}>
          <span class="text-xl">📝</span>
        </div>
        <h2 class="font-display font-bold text-xl">Fiche de synthèse</h2>
      </div>

      <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-6 sm:p-8 space-y-6">

        <div class="p-5 rounded-2xl" style={`background: ${subject.colorHex}08; border-left: 4px solid ${subject.colorHex};`}>
          <h3 class="font-display font-bold text-lg mb-2" style={`color: ${subject.colorHex};`}>
            🔑 Notions essentielles
          </h3>
          <div class="flex flex-wrap gap-2 mt-3">
            {chapter.notions.map(n => (
              <span class="badge bg-white shadow-sm text-gray-700">{n}</span>
            ))}
          </div>
        </div>

        <div class="prose prose-sm max-w-none">
          <h3 class="font-display font-bold text-lg">1. Definir le management</h3>
          <p>Le <strong>management</strong> designe l'ensemble des techniques et des pratiques permettant de gouverner une organisation, c'est-a-dire de piloter une production collective en tenant compte de multiples contraintes (humaines, financieres, juridiques, technologiques). Manager, c'est faire en sorte que les ressources disponibles soient combinees de la maniere la plus efficace possible pour atteindre les objectifs fixes.</p>
          <p>Le management concerne toutes les formes d'organisations : une entreprise industrielle, un hopital, une association sportive ou une collectivite territoriale ont toutes besoin d'etre managees pour remplir leur mission.</p>

          <h3 class="font-display font-bold text-lg mt-6">2. Les quatre fonctions du management</h3>
          <p>Le travail du manager s'articule autour de quatre grandes fonctions complementaires :</p>
          <ul>
            <li><strong>Fixer les objectifs</strong> : determiner ce que l'organisation doit accomplir a court, moyen et long terme. Les objectifs doivent etre clairs, mesurables et coherents avec la finalite de l'organisation.</li>
            <li><strong>Organiser le travail</strong> : repartir les taches, definir les responsabilites, mettre en place les procedures et allouer les ressources necessaires.</li>
            <li><strong>Animer les equipes</strong> : motiver les collaborateurs, developper leurs competences, gerer les conflits et creer un climat de travail favorable a la performance.</li>
            <li><strong>Controler et evaluer</strong> : mesurer les resultats obtenus, les comparer aux objectifs initiaux et prendre les mesures correctrices si des ecarts sont constates.</li>
          </ul>

          <h3 class="font-display font-bold text-lg mt-6">3. Management strategique et management operationnel</h3>
          <p>On distingue deux niveaux de management. Le <strong>management strategique</strong> releve de la direction generale. Il porte sur le long terme, engage l'ensemble de l'organisation et implique des decisions souvent irreversibles, comportant un degre eleve d'incertitude. Exemples : lancer une nouvelle gamme de produits, penetrer un marche etranger, fusionner avec un concurrent.</p>
          <p>Le <strong>management operationnel</strong>, en revanche, concerne la gestion quotidienne de l'activite. Il est porte par l'encadrement intermediaire et les responsables de terrain. Ses decisions sont a court terme, reversibles et a moindre risque. Exemples : planifier les equipes de la semaine, gerer un stock, traiter une reclamation client.</p>
          <p>Ces deux niveaux sont interdependants : la strategie fixe le cap, et l'operationnel traduit cette strategie en actions concretes sur le terrain. Un desequilibre entre les deux peut compromettre la performance globale.</p>
        </div>

        <div class="p-5 rounded-2xl bg-amber-50 border border-amber-100">
          <h4 class="font-display font-bold text-sm text-amber-800 mb-2">💡 À retenir pour l'examen</h4>
          <p class="text-sm text-amber-700">Maitrisez la distinction entre management strategique et operationnel : le premier engage le long terme avec des risques eleves, le second gere le quotidien. Sachez identifier les quatre fonctions du management dans un cas concret et montrer en quoi elles se completent. Le sujet vous demandera souvent de classer des decisions dans l'un ou l'autre niveau.</p>
        </div>
      </div>
    </section>

    {questions.length > 0 && (
      <section class="mb-16">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-2xl flex items-center justify-center" style={`background: ${subject.colorHex}15;`}>
            <span class="text-xl">🎯</span>
          </div>
          <h2 class="font-display font-bold text-xl">QCM — Teste tes connaissances</h2>
          <span class="badge text-xs" style={`background: ${subject.colorHex}15; color: ${subject.colorHex};`}>
            {questions.length} questions
          </span>
        </div>
        <QCMEngine client:load questions={questions} subjectColor={subject.colorHex} chapterTitle={chapter.title} />
      </section>
    )}

    {flashcardSet && (
      <section class="mb-16">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-2xl flex items-center justify-center" style={`background: ${subject.colorHex}15;`}>
            <span class="text-xl">⚡</span>
          </div>
          <h2 class="font-display font-bold text-xl">Fiches Flash</h2>
          <span class="badge text-xs" style={`background: ${subject.colorHex}15; color: ${subject.colorHex};`}>
            {flashcardSet.cards.length} notions
          </span>
        </div>
        <FichesFlash client:load cards={flashcardSet.cards} subjectColor={subject.colorHex} title={chapter.title} />
      </section>
    )}

    <nav class="flex items-center justify-between pt-8 border-t border-gray-100">
      {prevChapter ? (
        <a href={`/premiere/management/${prevChapter.slug}`} class="flex items-center gap-3 group text-sm text-gray-500 hover:text-gray-800 transition-colors">
          <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
          <div>
            <span class="text-xs text-gray-400">Précédent</span>
            <p class="font-medium">{prevChapter.title}</p>
          </div>
        </a>
      ) : <div />}
      {nextChapter ? (
        <a href={`/premiere/management/${nextChapter.slug}`} class="flex items-center gap-3 group text-sm text-gray-500 hover:text-gray-800 transition-colors text-right">
          <div>
            <span class="text-xs text-gray-400">Suivant</span>
            <p class="font-medium">{nextChapter.title}</p>
          </div>
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
      ) : <div />}
    </nav>

  </div>

</Layout>
